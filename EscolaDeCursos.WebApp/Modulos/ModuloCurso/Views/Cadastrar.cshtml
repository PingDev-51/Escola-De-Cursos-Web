@using EscolaDeCursos.WebApp.Modulos.ModuloCurso
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Curso";
}

@model CadastrarCursoViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Cadastrar" method="post">
    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
        <input asp-for="Nome" type="text" class="form-control">
        <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
    </div>

    @using EscolaDeCursos.Dominio.Modulos.ModuloCursos

    <div class="mb-3">
        <label asp-for="Nivel" class="form-label fw-semibold text-primary text-uppercase small">Nivel</label>
        <select asp-for="Nivel" class="form-select">
            <option value="@Nivel.Facil">Fácil</option>
            <option value="@Nivel.Medio">Médio</option>
            <option value="@Nivel.Dificil">Difícil</option>
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="CargaHoraria" class="form-label fw-semibold text-primary text-uppercase small">Carga Horaria</label>
        <input asp-for="CargaHoraria" type="number" class="form-control">
        <span asp-validation-for="CargaHoraria" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ModuloId" class="form-label fw-semibold text-primary text-uppercase small">Modulos</label>
        <select asp-for="ModuloId" class="form-select">
            <option value="">Selecione um Modulo</option>
            @foreach (OpcaoModuloViewModel modulo in Model.Modulos)
            {
                <option value="@modulo.Id">@modulo.Nome</option>
            }
        </select>
        <span asp-validation-for="ModuloId" class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
</form>