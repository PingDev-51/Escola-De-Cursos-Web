@using EscolaDeCursos.WebApp.Modulos.ModuloMatricula

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Matriculas";
}

@model List<ListarMatriculaViewModel>


@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhum aluno cadastrado.
    </div>
}
else
{
   <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
    @foreach (ListarMatriculaViewModel m in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">

                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h5 class="card-title mb-0">@m.AlunoNome</h5>
                        <span class="badge bg-primary rounded-pill">
                            @m.Id.ToString()[..8]
                        </span>
                    </div>

                    <dl class="row mb-4">

                        <dt class="col-5 text-secondary">Matricula</dt>
                        <dd class="col-7">@m.MatriculaId.ToString().Substring(0, 8)</dd>
                    </dl>

                    <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">

                        <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                           asp-action="Excluir"
                           asp-route-id="@m.Id">
                            Excluir
                        </a>

                    </div>

                </div>
            </div>
        </div>
    }
    </div>
}