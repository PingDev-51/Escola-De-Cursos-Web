@using EscolaDeCursos.WebApp.Modulos.ModuloMatricula
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Item";
}

@model CadastrarMatriculaViewModel;


<div class="card border-primary-subtle shadow-sm mx-auto mb-3 p-3" style="max-width: 620px;">
    <div class="d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@Model.TurmaNome</h5>
    </div>
</div>

@if (Model.Alunos.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3 mx-auto" style="max-width: 620px;" role="alert">
        Cadastre um Aluno antes de matricular na turma.
    </div>
}

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Cadastrar" method="post">
    <input asp-for="TurmaId" type="hidden">

    <div class="mb-3">
        <label asp-for="AlunosId" class="form-label fw-semibold text-primary text-uppercase small">Aluno</label>
        <select asp-for="AlunosId" class="form-select">
            <option value="">Selecione um Aluno</option>
            @foreach (OpcaoAlunoViewModel aluno in Model.Alunos)
            {
                <option value="@aluno.Id">@aluno.Nome</option>
            }
        </select>
        <span asp-validation-for="AlunosId" class="text-danger small fw-semibold"></span>
    </div>

        <div class="d-flex justify-content-end gap-2">
            <a class="btn btn-outline-primary rounded-pill px-4" asp-controller="Turma" asp-action="Listar"">Voltar</a>
            @if (Model.Alunos.Count == 0)
            {
                <button class="btn btn-primary rounded-pill px-4" type="submit" disabled>Confirmar</button>
            }
            else
            {
                <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
            }
        </div>
    </div>
</form>