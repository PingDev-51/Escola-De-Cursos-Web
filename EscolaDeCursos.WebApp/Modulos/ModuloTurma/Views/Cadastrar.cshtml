@using EscolaDeCursos.WebApp.Modulos.ModuloTurma

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Turmas";
}

@model CadastrarTurmaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 720px;" asp-action="Cadastrar" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger small fw-semibold mb-3"></div>

    <div class="mb-3">
        <label asp-for="Nome" class="form-label fw-semibold text-primary text-uppercase small">Nome</label>
        <input asp-for="Nome" type="text" class="form-control">
        <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="InstrutorId" class="form-label fw-semibold text-primary text-uppercase small">Instrutores</label>
        <select asp-for="InstrutorId" class="form-select">
            <option value="">Selecione um Instrutores</option>
            @foreach (OpcaoInstrutorViewModel instrutor in Model.Instrutor)
            {
                <option value="@instrutor.Id">@instrutor.Nome</option>
            }
        </select>
        <span asp-validation-for="InstrutorId" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CursoId" class="form-label fw-semibold text-primary text-uppercase small">Curso</label>
        <select asp-for="CursoId" class="form-select">
            <option value="">Selecione um Curso</option>
            @foreach (OpcaoCursoViewModel curso in Model.Curso)
            {
                <option value="@curso.Id">@curso.Nome</option>
            }
        </select>
        <span asp-validation-for="CursoId" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="NumeroMaxDeAlunos" class="form-label fw-semibold text-primary text-uppercase small">Numero Maximo De Alunos</label>
        <input asp-for="NumeroMaxDeAlunos" type="number" class="form-control">
        <span asp-validation-for="NumeroMaxDeAlunos" class="text-danger small fw-semibold"></span>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="DataInicio" class="form-label fw-semibold text-primary text-uppercase small">Data de Inicio</label>
            <input asp-for="DataInicio" type="date" class="form-control">
            <span asp-validation-for="DataInicio" class="text-danger small fw-semibold"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="DataTermino" class="form-label fw-semibold text-primary text-uppercase small">Data de Termino</label>
            <input asp-for="DataTermino" type="date" class="form-control">
            <span asp-validation-for="DataTermino" class="text-danger small fw-semibold"></span>
        </div>

    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>

   
</form>