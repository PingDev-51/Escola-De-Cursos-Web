@using EscolaDeCursos.WebApp.Modulos.ModuloTurma

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Turmas";
}

@model List<ListaTurmaViewModel>

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Novo</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhuma turma cadastrada.
    </div>
}
else
{
   <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
    @foreach (ListaTurmaViewModel t in Model)
    {
        <div class="col">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex flex-column">

                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h5 class="card-title mb-0">@t.Nome</h5>
                        <span class="badge bg-primary rounded-pill">
                            @t.Id.ToString()[..8]
                        </span>
                    </div>

                    <dl class="row mb-4">

                        <dt class="col-5 text-secondary">Instrutor</dt>
                        <dd class="col-7">@t.InstrutorNome</dd>

                        <dt class="col-5 text-secondary">Curso</dt>
                        <dd class="col-7">@t.CursoNome</dd>

                        <dt class="col-5 text-secondary">Nº Máx. Alunos</dt>
                        <dd class="col-7">@t.NumeroMaxDeAlunos</dd>

                        <dt class="col-5 text-secondary">Data Início</dt>
                        <dd class="col-7">@t.DataInicio.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-5 text-secondary">Data Término</dt>
                        <dd class="col-7">@t.DataTermino.ToString("dd/MM/yyyy")</dd>

                    </dl>

                    <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">

                        <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                           asp-action="Editar"
                           asp-route-id="@t.Id">
                            Editar
                        </a>

                        <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                           asp-action="Excluir"
                           asp-route-id="@t.Id">
                            Excluir
                        </a>

                        <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                           asp-controller="Matricula"
                           asp-action="Cadastrar"
                            asp-route-id="@t.Id">
                            Matricular Alunos
                        </a>

                    </div>

                </div>
            </div>
        </div>
    }
    </div>
}