@using EscolaDeCursos.WebApp.Modulos.ModuloTurma
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Turmas";
}

@model List<ListaTurmaViewModel>;

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Novo</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhuma turma cadastrada.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (ListaTurmaViewModel t in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0">@t.Nome</h5>
                            <span class="badge text-bg-primary rounded-pill">@t.Id.ToString().Substring(0, 8)</span>
                        </div>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Instutor</dt>
                            <dd class="col-7 mb-0 text-break">@t.InstrutorNome</dd>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Curso</dt>
                            <dd class="col-7 mb-0 text-break">@t.CursoNome</dd>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Numero Maximo De Alunos</dt>
                            <dd class="col-7 mb-0 text-break">@t.NumeroMaxDeAlunos</dd>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">DataInicio</dt>
                            <dd class="col-7 mb-0">@t.DataInicio.ToString("dd/MM/yyyy")</dd>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">DataTermino</dt>
                            <dd class="col-7 mb-0">@t.DataTermino.ToString("dd/MM/yyyy")</dd>

                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar" asp-route-id="@t.Id">Editar</a>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir" asp-route-id="@t.Id">Excluir</a>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-controller="Matricula" asp-action="Listar">Matricular Alunos</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}