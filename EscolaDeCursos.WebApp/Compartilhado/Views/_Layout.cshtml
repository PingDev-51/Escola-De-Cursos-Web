<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    @* Importação do CSS do Bootstrap *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

    <title>@ViewBag.Titulo - Escola de Cursos</title>
</head>

<body>
    @* Barra de Navegação *@
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
        <div class="container">
            <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">Escola de Cursos</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal"
                    aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menuPrincipal">
             @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="navbar-nav ms-auto">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Início</a>
                        <a class="nav-link" asp-controller="Categoria" asp-action="Listar">Categorias</a>
                        <a class="nav-link" asp-controller="Curso" asp-action="Listar">Cursos</a>
                        <a class="nav-link" asp-controller="Instrutor" asp-action="Listar">Instrutores</a>
                        <a class="nav-link" asp-controller="Aluno" asp-action="Listar">Alunos</a>
                        <a class="nav-link" asp-controller="Turma" asp-action="Listar">Turmas</a>
                        <a class="nav-link" asp-controller="Matricula" asp-action="Listar">Matrículas</a>
                    </div>

                    <div class="dropdown ms-3">
                        <button class="btn btn-outline-primary rounded-pill btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            @User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <form asp-controller="Autenticacao" asp-action="Sair" method="post" class="d-inline">
                                    <button type="submit" class="dropdown-item text-danger">Sair</button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <div class="navbar-nav ms-auto">
                        <a class="nav-link" asp-controller="Autenticacao" asp-action="Entrar">Entrar</a>
                        <a class="nav-link" asp-controller="Autenticacao" asp-action="Registrar">Registrar</a>
                    </div>
                }
            </div>
        </div>
    </nav>

    @* Cabeçalho da Página *@
    <header class="container py-4">
        <h2>@ViewBag.Titulo</h2>
    </header>

    @* Conteúdo da Página *@
    <main class="container pb-5">
        @RenderBody()
    </main>

    @* Importação do JavaScript do Bootstrap *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>
</body>

</html>
